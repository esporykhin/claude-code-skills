# Kaiten API credentials
# Скопируй в config/.env и подставь свои значения. Файл в .gitignore.

# Хост инсталляции Kaiten (с протоколом или без).
# Примеры: mycompany.kaiten.ru, https://kaiten.mycompany.io
KAITEN_DOMAIN=YOUR_DOMAIN

# Персональный API-токен.
# Получить: Kaiten → аватар → Профиль → вкладка API → Create new API token.
KAITEN_TOKEN=YOUR_KAITEN_TOKEN
