# amoCRM private integration credentials
# Скопируй этот файл в config/.env и подставь свои значения.
# config/.env не коммитится в git (добавлен в .gitignore).

# Поддомен аккаунта БЕЗ .amocrm.ru — например, для mycompany.amocrm.ru вписывай mycompany
AMOCRM_SUBDOMAIN=YOUR_SUBDOMAIN

# Долгосрочный токен приватной интеграции.
# Получить: amoCRM → Настройки → Интеграции → Создать → Внутренняя интеграция →
#           Ключи и доступы → Сгенерировать долгосрочный токен.
AMOCRM_ACCESS_TOKEN=YOUR_LONG_LIVED_TOKEN

# Домен платформы. По умолчанию amocrm.ru; для .com-аккаунтов замени на amocrm.com.
AMOCRM_DOMAIN=amocrm.ru
