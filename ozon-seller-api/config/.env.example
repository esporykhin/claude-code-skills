# Ozon Seller API credentials
# Скопируй этот файл в config/.env и подставь свои значения.
# config/.env не коммитится в git.

# Client-Id магазина (Ozon Seller Кабинет → Настройки → API)
OZON_CLIENT_ID=YOUR_CLIENT_ID

# Api-Key магазина (там же, вкладка "API ключи")
OZON_API_KEY=YOUR_API_KEY

# Base URL (по умолчанию api-seller.ozon.ru; менять обычно не нужно)
# OZON_SELLER_BASE_URL=https://api-seller.ozon.ru
