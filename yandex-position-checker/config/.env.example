# Yandex Position Checker skill configuration
# Скопируй в config/.env и подставь значения. Файл в .gitignore.

# Base URL для публичного чекера позиций. По умолчанию https://loocl.ru.
YANDEX_POSITION_CHECKER_BASE_URL=https://loocl.ru

# (Опционально) Ключ Яндекс.Геокодера — включает поиск по адресу в России.
# Получить: https://developer.tech.yandex.ru (бесплатный тариф)
# YANDEX_GEOCODER_API_KEY=YOUR_KEY
