# Dokploy API credentials
# Скопируй файл в config/.env и подставь свои значения.
# config/.env не коммитится (см. .gitignore).

# Базовый URL Dokploy-инстанса (с протоколом и портом, без trailing slash).
# Пример: http://212.67.12.194:3000  или  https://dokploy.example.com
DOKPLOY_URL=http://YOUR-DOKPLOY-HOST:3000

# API-токен. Получить:
#   Dokploy UI → Settings → API/CLI → Generate token.
DOKPLOY_API_KEY=YOUR_API_KEY
